# DocflowWeb — Document Management System
# Shared environment configuration for local development

# PostgreSQL
POSTGRES_USER=dms
POSTGRES_PASSWORD=dms
POSTGRES_DB=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dms_redis

# JWT
JWT_SECRET=your-jwt-secret-here
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
VERIFICATION_TOKEN_TTL=24h
PASSWORD_RESET_TTL=1h

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your_email@example.com

# Frontend
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_RPM=100

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# NATS
NATS_URL=nats://nats:4222
LOG_SUBJECT=queue.logs
MAIL_JOB_SUBJECT=queue.mail.jobs
NOTIFICATION_SUBJECT=queue.notification.events

# Service addresses for API Gateway
AUTH_SERVICE_ADDR=auth-service:9001
USER_SERVICE_ADDR=user-service:9002
DOCUMENT_SERVICE_ADDR=document-service:9003
TASK_SERVICE_ADDR=task-service:9004
CALENDAR_SERVICE_ADDR=calendar-service:9005
NOTIFICATION_SERVICE_ADDR=notification-service:9006
MAIL_SERVICE_ADDR=mail-service:9007

# Cache TTL
CACHE_TTL=5m
